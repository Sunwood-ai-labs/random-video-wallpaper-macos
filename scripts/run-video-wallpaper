#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CALLER_CWD="$PWD"
PIDFILE="$ROOT/.video-wallpaper.pid"
APP="$ROOT/.build/Random Video Wallpaper.app"
APP_BIN="$APP/Contents/MacOS/random-video-wallpaper"
APP_PLIST="$APP/Contents/Info.plist"

if [[ $# -eq 0 || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  if [[ -x "$ROOT/.build/release/random-video-wallpaper" ]]; then
    "$ROOT/.build/release/random-video-wallpaper" --help
  else
    cat <<'USAGE'
Usage:
  scripts/run-video-wallpaper [options] <video-or-folder> [more videos/folders...]
USAGE
  fi
  cat <<'USAGE'

Build and start the video wallpaper:
  scripts/run-video-wallpaper ~/Movies/wallpapers
  scripts/run-video-wallpaper ~/Movies/wallpapers/vending-stigmata-loop-*.mp4
  scripts/run-video-wallpaper --fade 2.0 ~/Movies/wallpapers

Stop it:
  scripts/stop-video-wallpaper
USAGE
  if [[ $# -eq 0 ]]; then
    exit 64
  fi
  exit 0
fi

cd "$ROOT"
swift build -c release
"$ROOT/.build/release/random-video-wallpaper" --cwd "$CALLER_CWD" --check "$@" >/dev/null

mkdir -p "$APP/Contents/MacOS"
cp "$ROOT/.build/release/random-video-wallpaper" "$APP_BIN"
chmod +x "$APP_BIN"
cat >"$APP_PLIST" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleExecutable</key>
  <string>random-video-wallpaper</string>
  <key>CFBundleIdentifier</key>
  <string>dev.sunwood.random-video-wallpaper</string>
  <key>CFBundleName</key>
  <string>Random Video Wallpaper</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSUIElement</key>
  <true/>
</dict>
</plist>
PLIST

"$ROOT/scripts/stop-video-wallpaper" >/dev/null 2>&1 || true

/usr/bin/open -n -g "$APP" --args --cwd "$CALLER_CWD" "$@"
sleep 1

PID="$(pgrep -f "$APP_BIN" | tail -n 1 || true)"
if [[ -n "$PID" ]]; then
  echo "$PID" >"$PIDFILE"
  echo "Started video wallpaper, pid $PID."
else
  rm -f "$PIDFILE"
  echo "Asked macOS to start the video wallpaper, but could not confirm the pid."
fi
